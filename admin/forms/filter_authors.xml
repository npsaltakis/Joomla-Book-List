<?xml version="1.0" encoding="utf-8"?>
<form>
	<fields name="filter">
		<field name="search" type="text" label="JSEARCH_FILTER_LABEL" hint="JSEARCH_FILTER" />
		<field name="state" type="list" label="JOPTION_SELECT_PUBLISHED" onchange="this.form.submit();">
			<option value="">JOPTION_SELECT_PUBLISHED</option>
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
		</field>
	</fields>
	<fields name="list">
		<field name="fullordering" type="list" label="JGLOBAL_SORT_BY" default="a.lastname ASC" onchange="this.form.submit();">
			<option value="">JGLOBAL_SORT_BY</option>
			<option value="a.lastname ASC">COM_BOOKS_LIST_SORT_LASTNAME_ASC</option>
			<option value="a.lastname DESC">COM_BOOKS_LIST_SORT_LASTNAME_DESC</option>
			<option value="a.name ASC">COM_BOOKS_LIST_SORT_NAME_ASC</option>
		</field>
		<field name="limit" type="limitbox" label="JGLOBAL_LIST_LIMIT" default="20" onchange="this.form.submit();" />
	</fields>
</form>
