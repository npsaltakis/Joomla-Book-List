<?xml version="1.0" encoding="utf-8"?>
<form>
	<fields name="filter">
		<field name="search" type="text" label="JSEARCH_FILTER_LABEL"
			hint="JSEARCH_FILTER" />

		<field name="state" type="list" label="JOPTION_SELECT_PUBLISHED"
			onchange="this.form.submit();">
			<option value="">JOPTION_SELECT_PUBLISHED</option>
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
			<option value="2">JARCHIVED</option>
			<option value="-2">JTRASHED</option>
		</field>

		<field name="catid" type="category" extension="com_books_list"
			label="COM_BOOKS_LIST_FIELD_CATID_LABEL" onchange="this.form.submit();">
			<option value="">JOPTION_SELECT_CATEGORY</option>
		</field>

		<field name="editor_id" type="editorlist"
			addfieldprefix="Nickpsal\Component\BooksList\Administrator\Field"
			label="COM_BOOKS_LIST_FIELD_EDITOR_LABEL" onchange="this.form.submit();">
			<option value="">COM_BOOKS_LIST_FIELD_EDITOR_LABEL</option>
		</field>

		<field name="language" type="contentlanguage" label="JOPTION_SELECT_LANGUAGE"
			onchange="this.form.submit();">
			<option value="">JOPTION_SELECT_LANGUAGE</option>
		</field>
	</fields>

	<fields name="list">
		<field name="fullordering" type="list" label="JGLOBAL_SORT_BY"
			default="a.title ASC" onchange="this.form.submit();">
			<option value="">JGLOBAL_SORT_BY</option>
			<option value="a.title ASC">COM_BOOKS_LIST_SORT_TITLE_ASC</option>
			<option value="a.title DESC">COM_BOOKS_LIST_SORT_TITLE_DESC</option>
			<option value="a.year ASC">COM_BOOKS_LIST_SORT_YEAR_ASC</option>
			<option value="a.year DESC">COM_BOOKS_LIST_SORT_YEAR_DESC</option>
			<option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
			<option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
		</field>

		<field name="limit" type="limitbox" label="JGLOBAL_LIST_LIMIT"
			default="20" onchange="this.form.submit();" />
	</fields>
</form>
