<?xml version="1.0" encoding="utf-8"?>
<config>
	<fieldset name="component" label="COM_BOOKS_LIST_CONFIGURATION">
		<field name="books_per_page" type="number" default="12"
			label="COM_BOOKS_LIST_CONFIG_PER_PAGE_LABEL" min="1" max="100" />

		<field name="show_cover" type="radio" layout="joomla.form.field.radio.switcher" default="1"
			label="COM_BOOKS_LIST_CONFIG_SHOW_COVER_LABEL">
			<option value="0">JHIDE</option>
			<option value="1">JSHOW</option>
		</field>

		<field name="show_filters" type="radio" layout="joomla.form.field.radio.switcher" default="1"
			label="COM_BOOKS_LIST_CONFIG_SHOW_FILTERS_LABEL">
			<option value="0">JHIDE</option>
			<option value="1">JSHOW</option>
		</field>

		<field name="show_rating" type="radio" layout="joomla.form.field.radio.switcher" default="1"
			label="COM_BOOKS_LIST_CONFIG_SHOW_RATING_LABEL">
			<option value="0">JHIDE</option>
			<option value="1">JSHOW</option>
		</field>
	</fieldset>

	<fieldset name="permissions" label="JCONFIG_PERMISSIONS_LABEL" description="JCONFIG_PERMISSIONS_DESC">
		<field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL"
			class="inputbox" validate="rules" filter="rules" component="com_books_list" section="component" />
	</fieldset>
</config>
